{
  "mcpServers": {
    "praetor": {
      "type": "stdio",
      "command": "${HOME}/.cargo/bin/praetor-mcp",
      "env": {
        "PRAETOR_KEY": "${HOME}/.config/praetor/alice.key",
        "PRAETOR_PEERS": "${HOME}/.config/praetor/alice-peers.json",
        "PRAETOR_URL": "http://127.0.0.1:9440",
        "PRAETOR_AGENT_DB": "${HOME}/.local/state/praetor/alice-agent.redb"
      }
    }
  }
}
